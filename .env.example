# VBinvest local program defaults
VBINVEST_DB_MODE=sqlite
VBINVEST_SQLITE_PATH=<app-data-dir>/vbinvest.sqlite3

# PostgreSQL advanced modes
DATABASE_URL=<postgresql-url-for-advanced-mode>
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=vbinvest
POSTGRES_USER=vbinvest
POSTGRES_PASSWORD=<generate-local-password>

# Optional Korean disclosures
OPENDART_API_KEY=<optional-opendart-api-key>

# Optional AI API integration
AI_PROVIDER_NAME=<ai-provider-name>
AI_PROVIDER_BASE_URL=<openai-compatible-base-url>
AI_PROVIDER_MODEL=<ai-provider-model>
AI_API_KEY=<openai-compatible-api-key>

# Optional local app settings
OBSIDIAN_VAULT_PATH=<absolute-obsidian-vault-path>
VBINVEST_LANGUAGE=ko
